# LLM 配置（OpenAI 兼容接口，不限于 DeepSeek）
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash

# Embedding 配置（切本地 LM Studio 时改 URL 和模型名，云端无需 API Key 则留空）
EMBEDDING_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/embeddings
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_API_KEY=
VECTOR_SIZE=1024
BATCH_SIZE=10

# Qdrant 配置
QDRANT_URL=http://127.0.0.1:6333
STAGING_ROOT=./qdrant/staging

# 搜索引擎 — tavily / brave
SEARCH_PROVIDER=tavily
SEARCH_API_KEY=

# 端口
PORT=3211
VITE_DEV_PORT=3210
